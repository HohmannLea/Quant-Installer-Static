<Page x:Class="BrukerAXS.QuantInstaller.Install"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BrukerAXS.QuantInstaller"
      mc:Ignorable="d"
      d:DesignHeight="680"
      d:DesignWidth="800"
      Title="Install Solutions"
      Margin="10,50,10,10">
    <Page.Resources>
        <Style BasedOn="{StaticResource ButtonTheme}"
               TargetType="Button" />
        <Style BasedOn="{StaticResource MenuButtonTheme}"
               TargetType="RadioButton" />
        <Style BasedOn="{StaticResource LabelStyle}"
               TargetType="Label" />
        <Style BasedOn="{StaticResource TextboxStyle}"
               TargetType="TextBox" />
        <Style BasedOn="{StaticResource TextBlockStyle}"
               TargetType="TextBlock" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Label Grid.Row="0"
               Content="Install Solutions"
               FontFamily="/Fonts/#Roboto-Light"
               FontSize="24"
               FontWeight="Bold" />

        <Label Grid.Row="1"
               Content="Select the instrument for which you wish to install your chosen method from the list below"
               FontFamily="/Fonts/#Roboto-Light"
               FontSize="14"
               FontWeight="Bold" />

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Grid.Row="2"
                      Height="550">

            <WrapPanel x:Name="Solutions"
                       Orientation="Horizontal"
                       Margin="0,20,0,0"
                       Width="780">
            </WrapPanel>

        </ScrollViewer>

        



    </Grid>
</Page>
