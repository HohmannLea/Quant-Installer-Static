<Page x:Class="BrukerAXS.QuantInstaller.Solution"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BrukerAXS.QuantInstaller"
      mc:Ignorable="d"
      d:DesignHeight="680"
      d:DesignWidth="800"
      Title="Solution"
      Margin="10,50,10,10">
    
    <Page.Resources>
        <Style BasedOn="{StaticResource ButtonTheme}"
               TargetType="Button" />
        <Style BasedOn="{StaticResource MenuButtonTheme}"
               TargetType="RadioButton" />
        <Style BasedOn="{StaticResource LabelStyle}"
               TargetType="Label" />
        <Style BasedOn="{StaticResource TextboxStyle}"
               TargetType="TextBox" />
        <Style BasedOn="{StaticResource TextBlockStyle}"
               TargetType="TextBlock" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtSolutionName" 
                   Grid.Row="0"
                   FontFamily="/Fonts/#Roboto-Light"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,10" />

        <TextBlock x:Name="txtDescription"
                   Grid.Row="1"
                   FontFamily="/Fonts/#Roboto-Light"
                   FontSize="14"
                   FontWeight="Regular"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <StackPanel Orientation="Horizontal"
                    Grid.Row="2">

            <ComboBox x:Name="Instruments"
                      FontFamily="/Fonts/#Roboto-Regular"
                      FontSize="14"
                      FontWeight="Bold"
                      HorizontalAlignment="Left"
                      HorizontalContentAlignment="Left"
                      VerticalContentAlignment="Center"
                      Width="250"
                      Height="30"
                      Background="#ffffff"
                      Foreground="#000000"
                      ScrollViewer.VerticalScrollBarVisibility="Visible"
                      MaxDropDownHeight="150">

                <ComboBoxItem Content="Select Instrument"
                              IsSelected="True"/>

            </ComboBox>

            <Button x:Name="btnInstall"
                    Grid.Row="2"
                    FontFamily="/Fonts/#Roboto-Light"
                    FontSize="13"
                    FontWeight="Bold"
                    Content="INSTALL"
                    Width="100"
                    Margin="10,0,0,0"
                    Click="btnInstall_Click" />


        </StackPanel>



    </Grid>

</Page>
