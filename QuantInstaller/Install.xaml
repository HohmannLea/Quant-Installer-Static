<Page x:Class="BrukerAXS.QuantInstaller.Install"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BrukerAXS.QuantInstaller"
      mc:Ignorable="d"
      d:DesignHeight="680"
      d:DesignWidth="800"
       Title="Select Instrument"
      Margin="10,50,10,10">
    <Page.Resources>
        <Style BasedOn="{StaticResource ButtonTheme}"
               TargetType="Button" />
        <Style BasedOn="{StaticResource MenuButtonTheme}"
               TargetType="RadioButton" />
        <Style BasedOn="{StaticResource LabelStyle}"
               TargetType="Label" />
        <Style BasedOn="{StaticResource TextboxStyle}"
               TargetType="TextBox" />
        <Style BasedOn="{StaticResource TextBlockStyle}"
               TargetType="TextBlock" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Label Grid.Row="0"
               Content="Select Instrument Configuration"
               FontFamily="/Fonts/#Roboto-Light"
               FontSize="24"
               FontWeight="Bold" />

        <Label Grid.Row="1"
               Content="Select the instrument configuration, then continue to choose the method"
               FontFamily="/Fonts/#Roboto-Light"
               FontSize="14"
               FontWeight="Bold" />

        <StackPanel Orientation="Horizontal"
                    Grid.Row="2"
                    Margin="0,20,0,0">

            <ComboBox x:Name="Instruments"
                      FontFamily="/Fonts/#Roboto-Regular"
                      FontSize="14"
                      FontWeight="Bold"
                      HorizontalAlignment="Left"
                      HorizontalContentAlignment="Left"
                      VerticalContentAlignment="Center"
                      Width="320"
                      Height="30"
                      Background="#ffffff"
                      Foreground="#000000"
                      ScrollViewer.VerticalScrollBarVisibility="Visible"
                      MaxDropDownHeight="220">

                <ComboBoxItem Content="Select Instrument"
                              IsSelected="True"/>

            </ComboBox>

            <Button x:Name="btnContinue"
                    FontFamily="/Fonts/#Roboto-Light"
                    FontSize="13"
                    FontWeight="Bold"
                    Content="CONTINUE"
                    Width="120"
                    Margin="10,0,0,0"
                    Click="btnContinue_Click" />

        </StackPanel>

        



    </Grid>
</Page>
