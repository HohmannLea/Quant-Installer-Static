                        </Viewbox>

                        <Image x:Name="CustomLogo"
                               Margin="0,50,0,0"
                               Width="114"
                               Height="61" />

                        <Label x:Name="TitleText"
                               FontFamily="/Fonts/#Roboto-Light"
                               FontSize="20"
                               Margin="0,10,0,0"
                               Foreground="White"
                               FontWeight="Bold" />
                    </StackPanel>
                </Border>

                <!-- Main Menu -->
                <Border Background="#054169"
                        Grid.Row="1"
                        CornerRadius="0,0,0,20"
                        BorderBrush="White"
                        BorderThickness="2,0,0,2">
                    <StackPanel VerticalAlignment="Top"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,0">
                        
