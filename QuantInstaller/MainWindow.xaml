<Window x:Class="BrukerAXS.QuantInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuantInstaller"
        mc:Ignorable="d"
        Title="Bruker AXS Solution Installer"
        Width="1000"
        Height="700"
        MinWidth="1000"
        MinHeight="700"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style BasedOn="{StaticResource ButtonTheme}"
               TargetType="Button" />
        <Style BasedOn="{StaticResource MenuButtonTheme}"
               TargetType="RadioButton" />
    </Window.Resources>

