  <FilterSpecification>
    <FilterInfos>
      <NameFilterInfo>
        <ParameterName>file_name(measurement_method)</ParameterName>
        <FilterString>PETRO-QUANT</FilterString>
      </NameFilterInfo>
      <NameFilterInfo>
        <ParameterName>specimen_name(specimen)</ParameterName>
        <FilterString>QC-XRS2</FilterString>
      </NameFilterInfo>
      <BitMaskFilter>
        <ParameterName>BitMaskForValidationIsValid</ParameterName>
